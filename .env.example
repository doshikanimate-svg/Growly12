# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BOT_TOKEN: Telegram bot token from @BotFather.
# Required to validate Telegram Mini App initData on the backend.
BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# FIREBASE_SERVICE_ACCOUNT_JSON: Firebase Admin service account (single-line JSON string).
# Used for issuing Firebase Custom Tokens for Telegram Mini App auth.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"my-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@my-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40my-project.iam.gserviceaccount.com"}'

# Telegram Payments settings for Growly Pro
TELEGRAM_PROVIDER_TOKEN="381764678:TEST:YOUR_PROVIDER_TOKEN"
TELEGRAM_PAYMENT_MODE="stars"
TELEGRAM_SUBSCRIPTION_PRICE_STARS_MONTH="199"
TELEGRAM_SUBSCRIPTION_PRICE_STARS_HALF_YEAR="999"
TELEGRAM_SUBSCRIPTION_PRICE_STARS_YEAR="1799"
TELEGRAM_SUBSCRIPTION_PRICE_RUB_KOPECS_MONTH="19900"
TELEGRAM_SUBSCRIPTION_PRICE_RUB_KOPECS_HALF_YEAR="99900"
TELEGRAM_SUBSCRIPTION_PRICE_RUB_KOPECS_YEAR="179900"
TELEGRAM_SUBSCRIPTION_DAYS_MONTH="30"
TELEGRAM_SUBSCRIPTION_DAYS_HALF_YEAR="180"
TELEGRAM_SUBSCRIPTION_DAYS_YEAR="365"

# Admin access (comma-separated Telegram IDs)
ADMIN_TELEGRAM_IDS="123456789,987654321"
VITE_ADMIN_TELEGRAM_IDS="123456789,987654321"
